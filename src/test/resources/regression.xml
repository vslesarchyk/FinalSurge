<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite thread-count="2"
       name="FinalSurge suite"
       parallel="tests">

    <listeners>
        <listener class-name="listeners.TestListener"></listener>
        <listener class-name="listeners.AnnotationTransformer"></listener>
    </listeners>

    <test name="Thread 1">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTest">
                <methods>
                    <include name="checkLoginWithNegativeCred"></include>
                </methods>
            </class>
            <class name="tests.LogoutTest"/>
        </classes>
    </test>

    <test name="Thread 2">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="tests.CalendarTest"/>
            <class name="tests.ShoesTest"/>
            <class name="tests.CalculatorTest"/>
            <class name="tests.ReportTest"/>
        </classes>
    </test>
</suite>

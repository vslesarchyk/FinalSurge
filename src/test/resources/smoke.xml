<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite thread-count="2"
       name="FinalSurge smoke suite"
       parallel="tests">

    <listeners>
        <listener class-name="listeners.TestListener"></listener>
        <listener class-name="listeners.AnnotationTransformer"></listener>
    </listeners>

    <test name="Smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <packages>
            <package name="tests"/>
        </packages>

    </test>
</suite>
